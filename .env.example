# ==============================================================================
# Job Board Portal - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values

# Django
DJANGO_SECRET_KEY=change-me-generate-with-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL)
POSTGRES_DB=jobboard
POSTGRES_USER=jobboard_user
POSTGRES_PASSWORD=change-me-strong-password

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Email (production — use SendGrid, Mailgun, or AWS SES)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# AWS S3 (for media storage in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend
FRONTEND_URL=https://yourdomain.com
VITE_API_URL=/api/v1

# Sentry (error tracking — optional)
# SENTRY_DSN=https://your-sentry-dsn

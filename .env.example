# ==============================================================================
# Job Board Portal - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values
# For local development, only DJANGO_SECRET_KEY and DATABASE_URL are required.
# ==============================================================================

# ─── DJANGO ───
DJANGO_SECRET_KEY=change-me-generate-with-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── DATABASE ───
# Local: leave empty for SQLite (development.py)
# Production (Neon): postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ─── GOOGLE OAUTH ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── EMAIL (Resend — free 3,000 emails/month) ───
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=JobBoard

# ─── EMAIL (SMTP fallback) ───
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── CLOUDINARY (free 25GB storage — replaces S3) ───
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ───
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── FRONTEND ───
FRONTEND_URL=http://localhost:5173

# ─── REDIS (optional — LocMem cache used in development) ───
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CHANNEL_LAYERS_REDIS_URL=redis://localhost:6379/2

# ─── SENTRY (optional) ───
# SENTRY_DSN=https://your-sentry-dsn
